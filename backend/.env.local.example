# Local-only backend overrides (copy to backend/.env.local)
# This file is ignored by git via root .gitignore.

# Option A: Use Railway public TCP proxy from local machine
DATABASE_URL=postgresql://postgres:replace_with_db_password@metro.proxy.rlwy.net:47885/railway
DB_SSL=true

# Option B: Use local PostgreSQL instead (uncomment and update password)
# DATABASE_URL=postgresql://postgres:replace_with_local_password@localhost:5432/clothvision
# DB_SSL=false

# Provider mode: vertex or studio
GEMINI_PROVIDER=vertex

# Optional compatibility switch (true also enables Vertex mode)
GOOGLE_GENAI_USE_VERTEXAI=true

# Vertex AI settings
GOOGLE_CLOUD_PROJECT=replace_with_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_API_KEY=replace_with_vertex_api_key

# Optional fallback for Gemini Developer API mode
GEMINI_API_KEY=replace_with_gemini_api_key
# Local frontend origin
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
