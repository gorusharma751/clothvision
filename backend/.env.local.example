# Local-only backend overrides (copy to backend/.env.local)
# This file is ignored by git via root .gitignore.

# Option A: Use Railway public TCP proxy from local machine
DATABASE_URL=postgresql://postgres:replace_with_db_password@metro.proxy.rlwy.net:47885/railway
DB_SSL=true

# Option B: Use local PostgreSQL instead (uncomment and update password)
# DATABASE_URL=postgresql://postgres:replace_with_local_password@localhost:5432/clothvision
# DB_SSL=false

# Local frontend origin
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
