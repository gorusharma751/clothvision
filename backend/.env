# ClothVision backend environment values
# Keep this file in sync with .env.example key list.

NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clothvision
JWT_SECRET=replace_with_secure_jwt_secret

GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=./uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ADMIN_EMAIL=admin@clothvision.com
ADMIN_PASSWORD=Admin@123
