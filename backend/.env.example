# Backend Environment Variables for ClothVision
# Copy this file to .env and update with your values

# Node Environment
NODE_ENV=production
PORT=5000

# Database (PostgreSQL)
# For Railway: Auto-generated when you connect PostgreSQL plugin
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://cvuser:cvpassword@localhost:5432/clothvision

# JWT Secret (generate a random string, min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_to_random_string_min_32_chars

# Gemini API (get free key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...your_key_here...
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Frontend URL (for CORS) - set to your Vercel domain
FRONTEND_URL=https://your-domain.vercel.app

# Upload Directory (production: /tmp or /var/uploads)
UPLOAD_DIR=./uploads

# Optional: Cloudinary (enable this to store product/generated images on Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin Credentials (auto-created on first startup)
ADMIN_EMAIL=admin@clothvision.com
ADMIN_PASSWORD=Admin@123
