# ClothVision backend environment template
# This is the single source of truth for env key names.

NODE_ENV=production
PORT=5000
TRUST_PROXY=1

# Use Railway Postgres connection string. If private host (postgres.railway.internal) fails,
# use Railway public URL instead.
DATABASE_URL=postgresql://username:password@host:5432/database
JWT_SECRET=replace_with_secure_jwt_secret

# Provider mode: vertex or studio
GEMINI_PROVIDER=vertex

# Optional compatibility switch (true also enables Vertex mode)
GOOGLE_GENAI_USE_VERTEXAI=true

# Vertex AI settings
GOOGLE_CLOUD_PROJECT=replace_with_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_API_KEY=replace_with_vertex_api_key

# Optional fallback for Gemini Developer API mode
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

FRONTEND_URL=https://your-frontend.vercel.app
UPLOAD_DIR=./uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ADMIN_EMAIL=admin@clothvision.com
ADMIN_PASSWORD=Admin@123
