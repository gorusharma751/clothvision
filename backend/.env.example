# ClothVision backend environment template
# This is the single source of truth for env key names.

NODE_ENV=production
PORT=5000
TRUST_PROXY=1

# Use Railway Postgres connection string. If private host (postgres.railway.internal) fails,
# use Railway public URL instead.
DATABASE_URL=postgresql://username:password@host:5432/database
JWT_SECRET=replace_with_secure_jwt_secret

# Vertex AI settings (required)
GOOGLE_CLOUD_PROJECT=replace_with_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_API_KEY=replace_with_vertex_api_key

# Optional: local ADC mode when VERTEX_API_KEY is not set
# GOOGLE_APPLICATION_CREDENTIALS=replace_with_service_account_json_path

# Models
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

FRONTEND_URL=https://your-frontend.vercel.app
UPLOAD_DIR=./uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ADMIN_EMAIL=admin@clothvision.com
ADMIN_PASSWORD=Admin@123
