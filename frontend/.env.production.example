# Frontend Production Environment Variables
# Copy this file to .env.production and update with your backend URL

# Backend API Base URL (Railway backend URL)
VITE_API_BASE_URL=https://your-railway-backend-url.railway.app/api

# Uploads Base URL (same as backend URL, no /api suffix)
VITE_UPLOADS_BASE_URL=https://your-railway-backend-url.railway.app
